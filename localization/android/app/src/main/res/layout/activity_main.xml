<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape layout. Mapping from the previous portrait version:
       top (URL + settings icon)  →  left side (settings icon only;
                                                URL is now inside dialog)
       middle (status + response) →  middle column
       bottom (Start / Stop)      →  right side
     Root is a FrameLayout so we can overlay the "Left" / "Right" wave
     labels on top of everything when recording starts.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Left: Settings icon -->
        <ImageButton
            android:id="@+id/settingsBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_settings"
            android:scaleType="centerInside"
            android:src="@drawable/ic_settings" />

        <!-- Middle: status code + response area -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statusCodeView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_code_default"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="8dp"
                android:fillViewport="true">

                <TextView
                    android:id="@+id/responseView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="8dp"
                    android:lineSpacingExtra="6dp"
                    android:text="@string/response_body_default"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textIsSelectable="true" />
            </ScrollView>
        </LinearLayout>

        <!-- Right: Start / Stop stack -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/startBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="120dp"
                android:text="@string/btn_start" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stopBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:enabled="false"
                android:minWidth="120dp"
                android:text="@string/btn_stop" />
        </LinearLayout>

    </LinearLayout>

    <!-- Overlay: "Left" / "Right" channel labels, faded in/out on Start. -->
    <TextView
        android:id="@+id/leftWaveLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|center_vertical"
        android:layout_marginStart="72dp"
        android:alpha="0"
        android:text="@string/wave_left"
        android:textAppearance="?attr/textAppearanceDisplaySmall"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/rightWaveLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="180dp"
        android:alpha="0"
        android:text="@string/wave_right"
        android:textAppearance="?attr/textAppearanceDisplaySmall"
        android:textStyle="bold" />

</FrameLayout>
